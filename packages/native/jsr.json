{
  "name": "@super-calendar/native",
  "version": "2.1.5",
  "description": "Gesture-driven, virtualized month / week / day calendar and date picker for React Native (and web via react-native-web).",
  "license": "MIT",
  "exports": {
    ".": "./src/index.tsx",
    "./picker": "./src/picker.tsx"
  },
  "imports": {
    "@super-calendar/core": "npm:@super-calendar/core@^2",
    "@legendapp/list": "npm:@legendapp/list@^3",
    "date-fns": "npm:date-fns@^4",
    "react": "npm:react@^19",
    "react-native": "npm:react-native@^0.85",
    "react-native-gesture-handler": "npm:react-native-gesture-handler@^2",
    "react-native-reanimated": "npm:react-native-reanimated@^4",
    "react-native-worklets": "npm:react-native-worklets@^0.8"
  },
  "publish": {
    "exclude": [
      "**/__tests__/**",
      "tsdown.config.mts"
    ]
  }
}
