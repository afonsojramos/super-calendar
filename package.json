{
  "name": "super-calendar",
  "version": "2.1.5",
  "private": true,
  "description": "Monorepo for super-calendar: a render-agnostic core with React Native and react-dom renderers.",
  "homepage": "https://github.com/afonsojramos/super-calendar#readme",
  "bugs": {
    "url": "https://github.com/afonsojramos/super-calendar/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afonsojramos/super-calendar.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "bench": "pnpm --filter @super-calendar/core bench",
    "parity:visual": "node scripts/visual-parity.mjs",
    "lint": "oxlint --type-aware packages",
    "lint:fix": "oxlint --fix --type-aware packages",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@legendapp/list": "^3.0.6",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-jest": "^29.7.0",
    "date-fns": "4.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-test-renderer": "19.2.3",
    "ts-morph": "^28.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.2"
}
