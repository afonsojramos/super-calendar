{
  "name": "react-native-super-calendar",
  "version": "0.6.0",
  "description": "A generic, themeable month/week/day calendar for React Native with pinch-to-zoom, virtualized paging, and a render-prop event API.",
  "keywords": [
    "agenda",
    "calendar",
    "day-view",
    "expo",
    "month-view",
    "react-native",
    "reanimated",
    "timetable",
    "web",
    "week-view"
  ],
  "homepage": "https://github.com/afonsojramos/react-native-super-calendar#readme",
  "bugs": {
    "url": "https://github.com/afonsojramos/react-native-super-calendar/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afonsojramos/react-native-super-calendar.git"
  },
  "source": "./src/index.tsx",
  "files": [
    "src",
    "dist",
    "README.md",
    "!**/__tests__",
    "!**/__mocks__"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.tsx",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "bench": "bun scripts/bench.ts",
    "lint": "oxlint --type-aware src && oxlint --type-aware example",
    "lint:fix": "oxlint --fix --type-aware src && oxlint --fix --type-aware example",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@legendapp/list": "^3.0.6",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "babel-jest": "^29.7.0",
    "date-fns": "4.4.0",
    "jest": "^29.7.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-test-renderer": "19.2.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@legendapp/list": ">=3",
    "date-fns": ">=3",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-gesture-handler": ">=2.16",
    "react-native-reanimated": ">=4.0.0 <5",
    "react-native-worklets": ">=0.5"
  },
  "packageManager": "pnpm@11.1.2"
}
