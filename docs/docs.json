{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "super-calendar",
  "colors": {
    "primary": "#1F6FEB",
    "light": "#4D8DF5",
    "dark": "#1A5FCC"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/mintlify-assets",
      "destination": "/"
    },
    {
      "source": "/guides/modes",
      "destination": "/guides/views"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": ["index", "why", "quickstart", "demo", "migrating-from-big-calendar"]
      },
      {
        "group": "Views",
        "pages": [
          "guides/views",
          "guides/month-view",
          "guides/year-view",
          "guides/time-grid",
          "guides/schedule",
          "guides/month-list",
          "guides/resource-timeline",
          "guides/date-picker"
        ]
      },
      {
        "group": "Events",
        "pages": [
          "guides/events",
          "guides/dragging",
          "guides/recurring-events",
          "guides/time-zones",
          "guides/ical"
        ]
      },
      {
        "group": "Styling",
        "pages": ["guides/theming", "guides/styling"]
      },
      {
        "group": "Interaction & accessibility",
        "pages": ["guides/selection", "guides/accessibility"]
      },
      {
        "group": "Packages & platforms",
        "pages": ["guides/dom", "guides/web", "guides/headless"]
      },
      {
        "group": "Reference",
        "pages": ["reference/renderers", "reference/api"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "",
        "icon": "npm",
        "iconType": "brands",
        "href": "https://www.npmjs.com/package/@super-calendar/native"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/afonsojramos/super-calendar"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/afonsojramos/super-calendar"
    }
  }
}
