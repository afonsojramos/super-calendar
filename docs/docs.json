{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "super-calendar",
  "colors": {
    "primary": "#1F6FEB",
    "light": "#4D8DF5",
    "dark": "#1A5FCC"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/mintlify-assets",
      "destination": "/"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": ["index", "why", "quickstart", "demo", "migrating-from-big-calendar"]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/events",
          "guides/dragging",
          "guides/modes",
          "guides/selection",
          "guides/month-list",
          "guides/headless",
          "guides/recurring-events",
          "guides/time-zones",
          "guides/ical",
          "guides/theming"
        ]
      },
      {
        "group": "Web",
        "pages": [
          "guides/dom",
          "guides/web",
          "guides/styling",
          "guides/date-picker",
          "guides/resource-timeline"
        ]
      },
      {
        "group": "Reference",
        "pages": ["reference/api", "reference/renderers"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "",
        "icon": "npm",
        "iconType": "brands",
        "href": "https://www.npmjs.com/package/@super-calendar/native"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/afonsojramos/super-calendar"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/afonsojramos/super-calendar"
    }
  }
}
